#!/usr/bin/env bash
# ╔══════════════════════════════════════════════════════════╗
# ║          DNYFappbuilder — Multi-Language Build System    ║
# ║          GitHub: https://github.com/DNYFTECH/dnyf-appbuilder ║
# ╚══════════════════════════════════════════════════════════╝
set -Eeuo pipefail

VERSION="2.0.0"
ABP_ROOT="${ABP_ROOT:-$HOME/dnyf-appbuilder}"
ABP_CONFIG="${ABP_CONFIG:-$ABP_ROOT/config/builder.json}"
ABP_LOG_DIR="${ABP_LOG_DIR:-$ABP_ROOT/logs}"
ABP_BUILD_DIR="${ABP_BUILD_DIR:-$ABP_ROOT/builds}"

# ── Colors ────────────────────────────────────────────────
RED='\e[1;31m'; GREEN='\e[1;32m'; YELLOW='\e[1;33m'
CYAN='\e[1;36m'; MAGENTA='\e[1;35m'; BLUE='\e[1;34m'
BOLD='\e[1m'; DIM='\e[2m'; RESET='\e[0m'

# ── Source libraries ──────────────────────────────────────
source_lib() {
    local lib="$ABP_ROOT/lib/$1"
    [[ -f "$lib" ]] && source "$lib" || true
}
source_lib common.sh
source_lib detect.sh
source_lib devices.sh
source_lib install.sh
source_lib signing.sh
source_lib notify.sh

# ── Banner ────────────────────────────────────────────────
show_banner() {
cat <<'BANNER'
 █████╗ ██████╗ ██████╗
██╔══██╗██╔══██╗██╔══██╗
███████║██████╔╝██████╔╝
██╔══██║██╔══██╗██╔═══╝
██║  ██║██████╔╝██║
╚═╝  ╚═╝╚═════╝ ╚═╝  DNYFappbuilder v2.0.0
BANNER
}

# ── Help ──────────────────────────────────────────────────
show_help() {
show_banner
cat <<HELP

${BOLD}USAGE:${RESET}
    abp <command> [options]

${BOLD}PROJECT COMMANDS:${RESET}
    ${CYAN}init${RESET} <name> <template>        Create a new project
    ${CYAN}build${RESET} <path> [options]         Build application
    ${CYAN}clean${RESET} [path]                   Clean build cache/artifacts

${BOLD}DEVICE COMMANDS:${RESET}
    ${CYAN}devices${RESET} [--wireless]            List connected devices
    ${CYAN}install${RESET} <app> [options]         Install built app to device(s)
    ${CYAN}uninstall${RESET} <package> [options]   Remove app from device(s)
    ${CYAN}screenshot${RESET} [--device <id>]      Capture device screenshot
    ${CYAN}logcat${RESET} [--device <id>]          Stream device logs

${BOLD}SIGNING COMMANDS:${RESET}
    ${CYAN}sign${RESET} <apk> [options]            Sign an APK
    ${CYAN}keygen${RESET} [options]                Generate a keystore
    ${CYAN}verify-sign${RESET} <apk>               Verify APK signature

${BOLD}DEPLOY COMMANDS:${RESET}
    ${CYAN}deploy${RESET} <target> [options]       Deploy to cloud/platform
    ${CYAN}docker${RESET} <action>                 Docker management

${BOLD}UTILITY COMMANDS:${RESET}
    ${CYAN}logs${RESET} [--tail N]                 View build logs
    ${CYAN}env${RESET} <action>                    Manage environment profiles
    ${CYAN}plugins${RESET} <action>                Manage plugins
    ${CYAN}update${RESET}                          Self-update DNYFappbuilder
    ${CYAN}doctor${RESET}                          Check environment health
    ${CYAN}version${RESET}                         Show version info
    ${CYAN}help${RESET}                            Show this help

${BOLD}TEMPLATES:${RESET}
    react-native    React Native mobile app (iOS/Android)
    flutter         Flutter cross-platform app
    nodejs          Node.js Express backend API
    python          Python FastAPI backend
    android         Native Android (Kotlin)
    java            Java Spring Boot API
    react           React web application
    vue             Vue.js web application

${BOLD}BUILD OPTIONS:${RESET}
    --target <t>       android | ios | web | all
    --profile <p>      debug | release | staging
    --parallel         Run builds in parallel
    --no-cache         Skip build cache
    --sign             Auto-sign after build
    --install          Install to device after build
    --notify           Send notification on completion
    --output <dir>     Custom output directory

${BOLD}INSTALL OPTIONS:${RESET}
    --device <serial>  Target specific device/emulator
    --all              Install to all connected devices
    --wireless <ip>    Install via WiFi ADB (Android)
    --qr               Show QR code for wireless install
    --verify           Verify installation after install
    --package <id>     App package ID for verification

${BOLD}DEPLOY TARGETS:${RESET}
    render             Deploy to Render.com
    railway            Deploy to Railway.app
    vercel             Deploy to Vercel
    heroku             Deploy to Heroku
    docker             Push to Docker registry
    github-pages       Deploy to GitHub Pages

${BOLD}EXAMPLES:${RESET}
    abp init myapp react-native
    abp build . --target android --profile release --sign
    abp build . --target all --parallel --notify
    abp devices
    abp devices --wireless
    abp install app.apk --all
    abp install app.apk --device emulator-5554
    abp install app.apk --wireless 192.168.1.10
    abp install app.apk --qr
    abp sign app.apk --keystore my.keystore --alias mykey
    abp deploy render --env production
    abp deploy railway
    abp doctor

${BOLD}DOCUMENTATION:${RESET}
    Docs:   $ABP_ROOT/docs/
    GitHub: https://github.com/DNYFTECH/dnyf-appbuilder

HELP
}

# ── Version ───────────────────────────────────────────────
show_version() {
cat <<VERSION
${BOLD}DNYFappbuilder v$VERSION${RESET}
Installation : $ABP_ROOT
Node.js      : $(node --version 2>/dev/null || echo "Not installed")
Python       : $(python3 --version 2>/dev/null || echo "Not installed")
Java         : $(java -version 2>&1 | head -1 || echo "Not installed")
Flutter      : $(flutter --version 2>/dev/null | head -1 || echo "Not installed")
Docker       : $(docker --version 2>/dev/null || echo "Not installed")
ADB          : $(adb --version 2>/dev/null | head -1 || echo "Not installed")
ios-deploy   : $(ios-deploy --version 2>/dev/null || echo "Not installed")
VERSION
}

# ── Init ──────────────────────────────────────────────────
cmd_init() {
    local name="${1:-myapp}" template="${2:-react-native}"
    log_info "Creating project: ${BOLD}$name${RESET} (template: $template)"
    bash "$ABP_ROOT/scripts/init.sh" "$name" "$template"
}

# ── Build ─────────────────────────────────────────────────
cmd_build() {
    local path="${1:-.}"; shift || true
    log_info "Building: ${BOLD}$path${RESET}"
    bash "$ABP_ROOT/scripts/build.sh" "$path" "$@"
}

# ── Devices ───────────────────────────────────────────────
cmd_devices() {
    bash "$ABP_ROOT/scripts/devices.sh" "$@"
}

# ── Install ───────────────────────────────────────────────
cmd_install() {
    if [[ $# -eq 0 ]]; then
        log_error "Usage: abp install <app-file> [options]"
        log_info  "Options: --device <id> | --all | --wireless <ip> | --qr | --verify"
        exit 1
    fi
    bash "$ABP_ROOT/scripts/install.sh" "$@"
}

# ── Uninstall ─────────────────────────────────────────────
cmd_uninstall() {
    if [[ $# -eq 0 ]]; then
        log_error "Usage: abp uninstall <package.id> [--device <id>|--all]"
        exit 1
    fi
    bash "$ABP_ROOT/scripts/uninstall.sh" "$@"
}

# ── Screenshot ────────────────────────────────────────────
cmd_screenshot() {
    bash "$ABP_ROOT/scripts/screenshot.sh" "$@"
}

# ── Logcat ────────────────────────────────────────────────
cmd_logcat() {
    local device_flag=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --device) device_flag="-s $2"; shift 2 ;;
            *) shift ;;
        esac
    done
    command_exists adb || { log_error "ADB not installed"; exit 1; }
    log_info "Streaming device logs (Ctrl+C to stop)..."
    # shellcheck disable=SC2086
    adb $device_flag logcat
}

# ── Sign ──────────────────────────────────────────────────
cmd_sign() {
    if [[ $# -eq 0 ]]; then
        log_error "Usage: abp sign <app.apk> [--keystore <path>] [--alias <alias>] [--auto]"
        exit 1
    fi
    bash "$ABP_ROOT/scripts/sign.sh" "$@"
}

# ── Keygen ────────────────────────────────────────────────
cmd_keygen() {
    bash "$ABP_ROOT/scripts/keygen.sh" "$@"
}

# ── Verify Sign ───────────────────────────────────────────
cmd_verify_sign() {
    local apk="${1:-}"
    [[ -z "$apk" ]] && { log_error "Usage: abp verify-sign <app.apk>"; exit 1; }
    [[ ! -f "$apk" ]] && { log_error "File not found: $apk"; exit 1; }
    log_info "Verifying signature: $apk"
    if command_exists apksigner; then
        apksigner verify --verbose "$apk"
    elif command_exists jarsigner; then
        jarsigner -verify -verbose "$apk"
    else
        log_error "Neither apksigner nor jarsigner found"
        exit 1
    fi
}

# ── Deploy ────────────────────────────────────────────────
cmd_deploy() {
    local target="${1:-help}"; shift || true
    case "$target" in
        render)       bash "$ABP_ROOT/scripts/deploy/deploy-render.sh" "$@" ;;
        railway)      bash "$ABP_ROOT/scripts/deploy/deploy-railway.sh" "$@" ;;
        vercel)       bash "$ABP_ROOT/scripts/deploy/deploy-vercel.sh" "$@" ;;
        heroku)       bash "$ABP_ROOT/scripts/deploy/deploy-heroku.sh" "$@" ;;
        docker)       bash "$ABP_ROOT/scripts/deploy/deploy-docker.sh" "$@" ;;
        github-pages) bash "$ABP_ROOT/scripts/deploy/deploy-ghpages.sh" "$@" ;;
        *)
            log_info "Available deploy targets:"
            echo "  render        Deploy to Render.com"
            echo "  railway       Deploy to Railway.app"
            echo "  vercel        Deploy to Vercel"
            echo "  heroku        Deploy to Heroku"
            echo "  docker        Push to Docker registry"
            echo "  github-pages  Deploy to GitHub Pages"
            ;;
    esac
}

# ── Docker ────────────────────────────────────────────────
cmd_docker() {
    local action="${1:-help}"; shift || true
    case "$action" in
        build)
            local tag="${1:-myapp:latest}"
            log_info "Building Docker image: $tag"
            docker build -t "$tag" .
            log_success "Image built: $tag"
            ;;
        run)
            local tag="${1:-myapp:latest}" port="${2:-3000}"
            log_info "Running container: $tag on port $port"
            docker run -d -p "$port:$port" --name abp-app "$tag"
            log_success "Container started"
            ;;
        push)
            local tag="${1:-}"
            [[ -z "$tag" ]] && { log_error "Usage: abp docker push <registry/image:tag>"; exit 1; }
            docker push "$tag"
            ;;
        compose-up)   docker compose up -d ;;
        compose-down) docker compose down ;;
        clean)
            log_warn "This will remove all unused Docker data. Continue? [y/N]"
            read -r confirm
            [[ "$confirm" =~ ^[Yy]$ ]] && docker system prune -af || log_info "Cancelled"
            ;;
        ps)    docker ps ;;
        logs)  docker logs abp-app -f ;;
        *)
            echo "Docker actions: build, run, push, compose-up, compose-down, clean, ps, logs"
            ;;
    esac
}

# ── Logs ──────────────────────────────────────────────────
cmd_logs() {
    local tail_n=50
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --tail) tail_n="$2"; shift 2 ;;
            -f|--follow) tail_n="+1"; shift ;;
            *) shift ;;
        esac
    done
    local logfile="$ABP_LOG_DIR/build.log"
    [[ ! -f "$logfile" ]] && { log_warn "No logs yet."; exit 0; }
    tail -n "$tail_n" "$logfile"
}

# ── Env ───────────────────────────────────────────────────
cmd_env() {
    local action="${1:-list}"; shift || true
    bash "$ABP_ROOT/scripts/env.sh" "$action" "$@"
}

# ── Plugins ───────────────────────────────────────────────
cmd_plugins() {
    local action="${1:-list}"; shift || true
    case "$action" in
        list)
            log_info "Installed plugins:"
            for plugin_dir in "$ABP_ROOT/plugins"/*/; do
                [[ -d "$plugin_dir" ]] && echo "  • $(basename "$plugin_dir")"
            done
            ;;
        install)
            local name="${1:-}"
            [[ -z "$name" ]] && { log_error "Usage: abp plugins install <name>"; exit 1; }
            log_info "Installing plugin: $name"
            # Plugin install logic
            ;;
        remove)
            local name="${1:-}"
            [[ -z "$name" ]] && { log_error "Usage: abp plugins remove <name>"; exit 1; }
            rm -rf "$ABP_ROOT/plugins/$name"
            log_success "Plugin removed: $name"
            ;;
        *)
            echo "Plugin actions: list, install, remove"
            ;;
    esac
}

# ── Update ────────────────────────────────────────────────
cmd_update() {
    bash "$ABP_ROOT/scripts/update.sh"
}

# ── Doctor ────────────────────────────────────────────────
cmd_doctor() {
    bash "$ABP_ROOT/scripts/doctor.sh"
}

# ── Clean ─────────────────────────────────────────────────
cmd_clean() {
    local path="${1:-}"
    if [[ -n "$path" && -d "$path" ]]; then
        log_info "Cleaning build artifacts in: $path"
        rm -rf "$path"/{build,dist,.dart_tool,.gradle,node_modules/.cache} 2>/dev/null || true
        log_success "Cleaned: $path"
    else
        log_info "Cleaning DNYFappbuilder cache..."
        rm -rf "$ABP_ROOT"/{.cache,builds}/* 2>/dev/null || true
        log_success "Cache cleared"
    fi
}

# ── Main ──────────────────────────────────────────────────
main() {
    # Ensure log dir exists
    mkdir -p "$ABP_LOG_DIR" "$ABP_BUILD_DIR"

    case "${1:-help}" in
        init)           shift; cmd_init "$@" ;;
        build)          shift; cmd_build "$@" ;;
        devices)        shift; cmd_devices "$@" ;;
        install)        shift; cmd_install "$@" ;;
        uninstall)      shift; cmd_uninstall "$@" ;;
        screenshot)     shift; cmd_screenshot "$@" ;;
        logcat)         shift; cmd_logcat "$@" ;;
        sign)           shift; cmd_sign "$@" ;;
        keygen)         shift; cmd_keygen "$@" ;;
        verify-sign)    shift; cmd_verify_sign "$@" ;;
        deploy)         shift; cmd_deploy "$@" ;;
        docker)         shift; cmd_docker "$@" ;;
        logs)           shift; cmd_logs "$@" ;;
        env)            shift; cmd_env "$@" ;;
        plugins)        shift; cmd_plugins "$@" ;;
        update)         cmd_update ;;
        doctor)         cmd_doctor ;;
        clean)          shift; cmd_clean "$@" ;;
        version|--version|-v) show_version ;;
        help|--help|-h) show_help ;;
        *)
            log_error "Unknown command: ${1}"
            echo "Run 'abp help' for usage."
            exit 1
            ;;
    esac
}

main "$@"
